BFS:

class Solution:
    def isCyclic(self, V, edges):
        # code here
        adj=[[] for _ in range(V)]
        indeg=[0]*V
        for u,v in edges:
            adj[u].append(v)
            indeg[v]+=1
        q=deque([]) # q=[]
        for i in range(V):
            if indeg[i]==0:
                q.append(i)
        c=0
        while q:
            node=q.popleft() # q.pop()
            c+=1
            for nei in adj[node]:
                indeg[nei]-=1
                if indeg[nei]==0:
                    q.append(nei)
        return c!=V


DFS:

class Solution:
    def isCyclic(self, V, edges):
        # code here
        adj=[[] for _ in range(V)]
        for u,v in edges:
            adj[u].append(v)
        visited=[False]*V
        path=[False]*V
        def dfs(node):
            visited[node]=True
            path[node]=True
            for nei in adj[node]:
                if not visited[nei]:
                    if dfs(nei):
                        return True
                elif path[nei]:
                    return True
            path[node]=False
            return False
        for i in range(V):
            if not visited[i]:
                if dfs(i):
                    return True
        return False
