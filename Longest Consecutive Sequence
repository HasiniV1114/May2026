class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        longest=0
        nset=set(nums)
        for nums in nset:
            if nums-1 not in nset:
                curr=nums
                length=1
                while curr+1 in nset:
                    curr+=1
                    length+=1
                longest=max(longest,length)
        return longest
